# Generate a random secret with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-secret
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production requires Postgres. Local development can use AI_PROVIDER=mock without POSTGRES_URL.
POSTGRES_URL=postgres://ai_workbench:ai_workbench_password@localhost:5432/ai_workbench

# deepseek is the default production provider. openai and mock are also supported.
AI_PROVIDER=deepseek
DEFAULT_CHAT_MODEL=deepseek-v4-flash
TITLE_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional OpenAI fallback.
OPENAI_API_KEY=

# Optional resumable stream/rate limit backend. Not required for v1.
REDIS_URL=

# Local file upload storage.
UPLOAD_DIR=./uploads

# Optional OCR languages for image uploads. Default: eng+chi_sim
OCR_LANGUAGES=eng+chi_sim
# Optional local/remote Tesseract traineddata path. Leave empty to use package defaults.
OCR_LANG_PATH=
# Prevent image OCR from blocking uploads for too long.
IMAGE_OCR_TIMEOUT_MS=15000
IMAGE_OCR_MAX_BYTES=5242880
